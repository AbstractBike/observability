{
  "title": "SkyWalking APM",
  "uid": "skywalking-apm",
  "description": "SkyWalking UI embedded via iframe alongside key PromQL metrics from OAP.",
  "schemaVersion": 39,
  "version": 1,
  "tags": ["apm", "skywalking", "tracing"],
  "editable": true,
  "graphTooltip": 1,
  "time": { "from": "now-1h", "to": "now" },
  "refresh": "30s",
  "annotations": { "list": [] },
  "links": [
    {
      "title": "Open SkyWalking UI",
      "url": "https://sky.abstract.bike/",
      "targetBlank": true,
      "type": "link",
      "icon": "external link"
    }
  ],
  "panels": [
    {
      "id": 1,
      "type": "text",
      "title": "SkyWalking UI",
      "description": "Full SkyWalking UI — service topology, traces, profiling.",
      "gridPos": { "h": 32, "w": 24, "x": 0, "y": 0 },
      "options": {
        "mode": "html",
        "content": "<iframe src=\"https://sky.abstract.bike/\" width=\"100%\" height=\"100%\" style=\"border:none;min-height:700px;\" allowfullscreen></iframe>",
        "code": { "language": "plaintext", "showLineNumbers": false, "showMiniMap": false }
      }
    },
    {
      "id": 2,
      "type": "timeseries",
      "title": "Service Call Rate (req/s)",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 32 },
      "datasource": { "type": "prometheus", "uid": "SkyWalking-PromQL" },
      "fieldConfig": {
        "defaults": {
          "unit": "reqps",
          "color": { "mode": "palette-classic" },
          "custom": { "lineWidth": 2, "fillOpacity": 10 }
        },
        "overrides": []
      },
      "options": { "legend": { "displayMode": "list", "placement": "bottom" }, "tooltip": { "mode": "multi" } },
      "targets": [
        {
          "expr": "sum by (service) (rate(service_cpm[5m]) / 60)",
          "legendFormat": "{{service}}",
          "refId": "A"
        }
      ]
    },
    {
      "id": 3,
      "type": "timeseries",
      "title": "Service Avg Response Time (ms)",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 32 },
      "datasource": { "type": "prometheus", "uid": "SkyWalking-PromQL" },
      "fieldConfig": {
        "defaults": {
          "unit": "ms",
          "color": { "mode": "palette-classic" },
          "custom": { "lineWidth": 2, "fillOpacity": 10 }
        },
        "overrides": []
      },
      "options": { "legend": { "displayMode": "list", "placement": "bottom" }, "tooltip": { "mode": "multi" } },
      "targets": [
        {
          "expr": "sum by (service) (service_resp_time)",
          "legendFormat": "{{service}}",
          "refId": "A"
        }
      ]
    },
    {
      "id": 4,
      "type": "timeseries",
      "title": "Service Error Rate (%)",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 40 },
      "datasource": { "type": "prometheus", "uid": "SkyWalking-PromQL" },
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "color": { "mode": "palette-classic" },
          "custom": { "lineWidth": 2, "fillOpacity": 10 },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 1 },
              { "color": "red", "value": 5 }
            ]
          }
        },
        "overrides": []
      },
      "options": { "legend": { "displayMode": "list", "placement": "bottom" }, "tooltip": { "mode": "multi" } },
      "targets": [
        {
          "expr": "sum by (service) (service_sla / 100)",
          "legendFormat": "{{service}} error%",
          "refId": "A"
        }
      ]
    },
    {
      "id": 5,
      "type": "timeseries",
      "title": "Endpoint P99 Latency (ms)",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 40 },
      "datasource": { "type": "prometheus", "uid": "SkyWalking-PromQL" },
      "fieldConfig": {
        "defaults": {
          "unit": "ms",
          "color": { "mode": "palette-classic" },
          "custom": { "lineWidth": 2, "fillOpacity": 10 }
        },
        "overrides": []
      },
      "options": { "legend": { "displayMode": "list", "placement": "bottom" }, "tooltip": { "mode": "multi" } },
      "targets": [
        {
          "expr": "sum by (endpoint) (endpoint_percentile{p=\"99\"})",
          "legendFormat": "{{endpoint}} p99",
          "refId": "A"
        }
      ]
    }
  ],
  "templating": { "list": [] }
}
