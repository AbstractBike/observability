{
  "__inputs": [
    {
      "name": "DS_VICTORIAMETRICS",
      "label": "VictoriaMetrics",
      "description": "",
      "type": "datasource",
      "pluginId": "prometheus",
      "pluginName": "Prometheus"
    }
  ],
  "__requires": [
    { "type": "grafana", "id": "grafana", "name": "Grafana", "version": "10.0.0" },
    { "type": "datasource", "id": "prometheus", "name": "Prometheus", "version": "1.0.0" },
    { "type": "panel", "id": "stat", "name": "Stat", "version": "" },
    { "type": "panel", "id": "timeseries", "name": "Time series", "version": "" },
    { "type": "panel", "id": "logs", "name": "Logs", "version": "" }
  ],
  "uid": "claude-proxy",
  "title": "Claude Proxy — Observability",
  "tags": ["claude", "proxy", "llm"],
  "timezone": "browser",
  "schemaVersion": 38,
  "refresh": "30s",
  "time": { "from": "now-1h", "to": "now" },
  "panels": [
    {
      "id": 1,
      "type": "stat",
      "title": "Total Requests",
      "gridPos": { "x": 0, "y": 0, "w": 4, "h": 4 },
      "datasource": { "type": "prometheus", "uid": "${DS_VICTORIAMETRICS}" },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "colorMode": "value", "graphMode": "area" },
      "fieldConfig": { "defaults": { "color": { "mode": "thresholds" }, "thresholds": { "steps": [{ "value": 0, "color": "green" }] } } },
      "targets": [{ "expr": "sum(increase(claude_proxy_requests_total[1h]))", "legendFormat": "requests/h" }]
    },
    {
      "id": 2,
      "type": "stat",
      "title": "Input Tokens",
      "gridPos": { "x": 4, "y": 0, "w": 4, "h": 4 },
      "datasource": { "type": "prometheus", "uid": "${DS_VICTORIAMETRICS}" },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "colorMode": "value", "graphMode": "area" },
      "fieldConfig": { "defaults": { "color": { "mode": "thresholds" }, "thresholds": { "steps": [{ "value": 0, "color": "blue" }] }, "unit": "short" } },
      "targets": [{ "expr": "sum(increase(claude_proxy_tokens_input_total[1h]))", "legendFormat": "tokens_in/h" }]
    },
    {
      "id": 3,
      "type": "stat",
      "title": "Output Tokens",
      "gridPos": { "x": 8, "y": 0, "w": 4, "h": 4 },
      "datasource": { "type": "prometheus", "uid": "${DS_VICTORIAMETRICS}" },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "colorMode": "value", "graphMode": "area" },
      "fieldConfig": { "defaults": { "color": { "mode": "thresholds" }, "thresholds": { "steps": [{ "value": 0, "color": "purple" }] }, "unit": "short" } },
      "targets": [{ "expr": "sum(increase(claude_proxy_tokens_output_total[1h]))", "legendFormat": "tokens_out/h" }]
    },
    {
      "id": 4,
      "type": "stat",
      "title": "Avg Latency",
      "gridPos": { "x": 12, "y": 0, "w": 4, "h": 4 },
      "datasource": { "type": "prometheus", "uid": "${DS_VICTORIAMETRICS}" },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "colorMode": "value", "graphMode": "area" },
      "fieldConfig": { "defaults": { "color": { "mode": "thresholds" }, "unit": "ms", "thresholds": { "steps": [{ "value": 0, "color": "green" }, { "value": 5000, "color": "yellow" }, { "value": 15000, "color": "red" }] } } },
      "targets": [{ "expr": "avg(claude_proxy_duration_ms)", "legendFormat": "avg latency" }]
    },
    {
      "id": 5,
      "type": "stat",
      "title": "Error Rate",
      "gridPos": { "x": 16, "y": 0, "w": 4, "h": 4 },
      "datasource": { "type": "prometheus", "uid": "${DS_VICTORIAMETRICS}" },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "colorMode": "background", "graphMode": "area" },
      "fieldConfig": { "defaults": { "unit": "percentunit", "color": { "mode": "thresholds" }, "thresholds": { "steps": [{ "value": 0, "color": "green" }, { "value": 0.01, "color": "yellow" }, { "value": 0.05, "color": "red" }] } } },
      "targets": [{ "expr": "sum(rate(claude_proxy_requests_total{status=~\"5..\"}[5m])) / sum(rate(claude_proxy_requests_total[5m]))", "legendFormat": "error rate" }]
    },
    {
      "id": 6,
      "type": "timeseries",
      "title": "Requests per Model",
      "gridPos": { "x": 0, "y": 4, "w": 12, "h": 8 },
      "datasource": { "type": "prometheus", "uid": "${DS_VICTORIAMETRICS}" },
      "options": { "tooltip": { "mode": "multi" } },
      "fieldConfig": { "defaults": { "custom": { "lineWidth": 2, "fillOpacity": 10 } } },
      "targets": [{ "expr": "sum by (model) (rate(claude_proxy_requests_total[5m]))", "legendFormat": "{{model}}" }]
    },
    {
      "id": 7,
      "type": "timeseries",
      "title": "Token Usage per Model",
      "gridPos": { "x": 12, "y": 4, "w": 12, "h": 8 },
      "datasource": { "type": "prometheus", "uid": "${DS_VICTORIAMETRICS}" },
      "options": { "tooltip": { "mode": "multi" } },
      "fieldConfig": { "defaults": { "custom": { "lineWidth": 2, "fillOpacity": 10 }, "unit": "short" } },
      "targets": [
        { "expr": "sum by (model) (rate(claude_proxy_tokens_input_total[5m]))", "legendFormat": "in:{{model}}" },
        { "expr": "sum by (model) (rate(claude_proxy_tokens_output_total[5m]))", "legendFormat": "out:{{model}}" }
      ]
    },
    {
      "id": 8,
      "type": "timeseries",
      "title": "Latency Distribution",
      "gridPos": { "x": 0, "y": 12, "w": 12, "h": 8 },
      "datasource": { "type": "prometheus", "uid": "${DS_VICTORIAMETRICS}" },
      "options": { "tooltip": { "mode": "multi" } },
      "fieldConfig": { "defaults": { "unit": "ms", "custom": { "lineWidth": 2, "fillOpacity": 10 } } },
      "targets": [{ "expr": "avg by (model) (claude_proxy_duration_ms)", "legendFormat": "{{model}}" }]
    },
    {
      "id": 9,
      "type": "timeseries",
      "title": "Errors by Status Code",
      "gridPos": { "x": 12, "y": 12, "w": 12, "h": 8 },
      "datasource": { "type": "prometheus", "uid": "${DS_VICTORIAMETRICS}" },
      "options": { "tooltip": { "mode": "multi" } },
      "fieldConfig": { "defaults": { "custom": { "lineWidth": 2, "fillOpacity": 10 }, "color": { "mode": "palette-classic" } } },
      "targets": [{ "expr": "sum by (status) (rate(claude_proxy_requests_total{status!=\"200\"}[5m]))", "legendFormat": "HTTP {{status}}" }]
    }
  ]
}
