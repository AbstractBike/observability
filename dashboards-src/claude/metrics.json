{
  "annotations": { "list": [] },
  "editable": true,
  "graphTooltip": 1,
  "id": null,
  "links": [],
  "panels": [
    {
      "type": "row", "title": "Today at a glance",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 0 },
      "id": 1, "collapsed": false
    },
    {
      "type": "stat", "title": "Cost USD",
      "gridPos": { "h": 4, "w": 4, "x": 0, "y": 1 }, "id": 2,
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "colorMode": "background", "graphMode": "none" },
      "fieldConfig": { "defaults": { "unit": "currencyUSD", "thresholds": { "steps": [
        { "color": "green", "value": null }, { "color": "yellow", "value": 5 }, { "color": "red", "value": 20 }
      ] } } },
      "targets": [{ "datasource": { "type": "victoriametrics-metrics-datasource" },
        "expr": "sum(last_over_time(claude_session_cost_usd[$__range]))", "legendFormat": "Cost" }]
    },
    {
      "type": "stat", "title": "Input tokens",
      "gridPos": { "h": 4, "w": 4, "x": 4, "y": 1 }, "id": 3,
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "colorMode": "value", "graphMode": "area" },
      "fieldConfig": { "defaults": { "unit": "short" } },
      "targets": [{ "datasource": { "type": "victoriametrics-metrics-datasource" },
        "expr": "sum(last_over_time(claude_tokens_input_total[$__range]))", "legendFormat": "Input" }]
    },
    {
      "type": "stat", "title": "Output tokens",
      "gridPos": { "h": 4, "w": 4, "x": 8, "y": 1 }, "id": 4,
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "colorMode": "value", "graphMode": "area" },
      "fieldConfig": { "defaults": { "unit": "short" } },
      "targets": [{ "datasource": { "type": "victoriametrics-metrics-datasource" },
        "expr": "sum(last_over_time(claude_tokens_output_total[$__range]))", "legendFormat": "Output" }]
    },
    {
      "type": "stat", "title": "Prompts",
      "gridPos": { "h": 4, "w": 4, "x": 12, "y": 1 }, "id": 5,
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "colorMode": "value", "graphMode": "area" },
      "fieldConfig": { "defaults": { "unit": "short" } },
      "targets": [{ "datasource": { "type": "victoriametrics-metrics-datasource" },
        "expr": "sum(last_over_time(claude_prompt_count[$__range]))", "legendFormat": "Prompts" }]
    },
    {
      "type": "stat", "title": "Avg duration (s)",
      "gridPos": { "h": 4, "w": 4, "x": 16, "y": 1 }, "id": 6,
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "colorMode": "value", "graphMode": "none" },
      "fieldConfig": { "defaults": { "unit": "s" } },
      "targets": [{ "datasource": { "type": "victoriametrics-metrics-datasource" },
        "expr": "sum(last_over_time(claude_duration_api_seconds[$__range])) / clamp_min(sum(last_over_time(claude_prompt_count[$__range])), 1)", "legendFormat": "Avg" }]
    },
    {
      "type": "stat", "title": "Lines added",
      "gridPos": { "h": 4, "w": 4, "x": 20, "y": 1 }, "id": 7,
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "colorMode": "value", "graphMode": "none" },
      "fieldConfig": { "defaults": { "unit": "short", "thresholds": { "steps": [
        { "color": "green", "value": null }
      ] } } },
      "targets": [{ "datasource": { "type": "victoriametrics-metrics-datasource" },
        "expr": "sum(last_over_time(claude_lines_added[$__range]))", "legendFormat": "Added" }]
    },

    {
      "type": "row", "title": "Token usage over time",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 5 },
      "id": 10, "collapsed": false
    },
    {
      "type": "timeseries", "title": "Tokens over time (input vs output)",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 6 }, "id": 11,
      "fieldConfig": { "defaults": { "unit": "short" } },
      "targets": [
        { "datasource": { "type": "victoriametrics-metrics-datasource" },
          "expr": "sum(claude_tokens_input_total)", "legendFormat": "Input" },
        { "datasource": { "type": "victoriametrics-metrics-datasource" },
          "expr": "sum(claude_tokens_output_total)", "legendFormat": "Output" }
      ]
    },
    {
      "type": "piechart", "title": "Tokens by model",
      "gridPos": { "h": 8, "w": 6, "x": 12, "y": 6 }, "id": 12,
      "targets": [{ "datasource": { "type": "victoriametrics-metrics-datasource" },
        "expr": "sum by (model) (last_over_time(claude_tokens_input_total[$__range]) + last_over_time(claude_tokens_output_total[$__range]))", "legendFormat": "{{model}}" }]
    },
    {
      "type": "barchart", "title": "Cost by model",
      "gridPos": { "h": 8, "w": 6, "x": 18, "y": 6 }, "id": 13,
      "fieldConfig": { "defaults": { "unit": "currencyUSD" } },
      "targets": [{ "datasource": { "type": "victoriametrics-metrics-datasource" },
        "expr": "sum by (model) (last_over_time(claude_session_cost_usd[$__range]))", "legendFormat": "{{model}}" }]
    },

    {
      "type": "row", "title": "By project",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 14 },
      "id": 20, "collapsed": false
    },
    {
      "type": "timeseries", "title": "Cost by project",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 15 }, "id": 21,
      "fieldConfig": { "defaults": { "unit": "currencyUSD" } },
      "targets": [{ "datasource": { "type": "victoriametrics-metrics-datasource" },
        "expr": "sum by (project) (claude_session_cost_usd)", "legendFormat": "{{project}}" }]
    },
    {
      "type": "timeseries", "title": "Tokens by project",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 15 }, "id": 22,
      "fieldConfig": { "defaults": { "unit": "short" } },
      "targets": [
        { "datasource": { "type": "victoriametrics-metrics-datasource" },
          "expr": "sum by (project) (claude_tokens_input_total + claude_tokens_output_total)", "legendFormat": "{{project}}" }
      ]
    },

    {
      "type": "row", "title": "Performance",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 23 },
      "id": 30, "collapsed": false
    },
    {
      "type": "timeseries", "title": "API duration (s) over time",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 24 }, "id": 31,
      "fieldConfig": { "defaults": { "unit": "s" } },
      "targets": [{ "datasource": { "type": "victoriametrics-metrics-datasource" },
        "expr": "sum(claude_duration_api_seconds)", "legendFormat": "Total API seconds" }]
    },
    {
      "type": "timeseries", "title": "Context usage %",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 24 }, "id": 32,
      "fieldConfig": { "defaults": { "unit": "percent", "min": 0, "max": 100 } },
      "targets": [{ "datasource": { "type": "victoriametrics-metrics-datasource" },
        "expr": "avg(claude_context_used_pct)", "legendFormat": "Avg context %" }]
    },

    {
      "type": "row", "title": "Code impact",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 32 },
      "id": 40, "collapsed": false
    },
    {
      "type": "timeseries", "title": "Lines added / removed",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 33 }, "id": 41,
      "fieldConfig": { "defaults": { "unit": "short" },
        "overrides": [{ "matcher": { "id": "byName", "options": "Removed" },
          "properties": [{ "id": "color", "value": { "fixedColor": "red", "mode": "fixed" } }] }]
      },
      "targets": [
        { "datasource": { "type": "victoriametrics-metrics-datasource" },
          "expr": "sum(claude_lines_added)", "legendFormat": "Added" },
        { "datasource": { "type": "victoriametrics-metrics-datasource" },
          "expr": "sum(claude_lines_removed)", "legendFormat": "Removed" }
      ]
    },
    {
      "type": "timeseries", "title": "Cache tokens (read / write)",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 33 }, "id": 42,
      "fieldConfig": { "defaults": { "unit": "short" } },
      "targets": [
        { "datasource": { "type": "victoriametrics-metrics-datasource" },
          "expr": "sum(claude_tokens_cache_read)", "legendFormat": "Cache read" },
        { "datasource": { "type": "victoriametrics-metrics-datasource" },
          "expr": "sum(claude_tokens_cache_write)", "legendFormat": "Cache write" }
      ]
    },

    {
      "type": "row", "title": "Model distribution by project",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 41 },
      "id": 50, "collapsed": false
    },
    {
      "type": "barchart", "title": "Model share % by project",
      "gridPos": { "h": 10, "w": 24, "x": 0, "y": 42 }, "id": 51,
      "options": {
        "stacking": "normal",
        "xField": "project",
        "fillOpacity": 70,
        "legend": { "displayMode": "list", "placement": "bottom" }
      },
      "fieldConfig": { "defaults": { "unit": "percent", "min": 0, "max": 100 } },
      "transformations": [
        { "id": "labelsToFields", "options": { "mode": "columns", "valueLabel": "model" } },
        { "id": "merge", "options": {} }
      ],
      "targets": [{ "datasource": { "type": "victoriametrics-metrics-datasource" },
        "expr": "sum by (project, model) (last_over_time(claude_tokens_input_total[$__range]) + last_over_time(claude_tokens_output_total[$__range])) / on(project) group_left() sum by (project) (last_over_time(claude_tokens_input_total[$__range]) + last_over_time(claude_tokens_output_total[$__range])) * 100",
        "instant": true, "legendFormat": "{{model}}" }]
    },
    {
      "type": "table", "title": "Token breakdown: project × model",
      "gridPos": { "h": 10, "w": 24, "x": 0, "y": 52 }, "id": 52,
      "options": { "sortBy": [{ "displayName": "Tokens", "desc": true }] },
      "fieldConfig": {
        "defaults": { "unit": "short" },
        "overrides": [
          { "matcher": { "id": "byName", "options": "%" },
            "properties": [{ "id": "unit", "value": "percent" }, { "id": "custom.width", "value": 80 }] },
          { "matcher": { "id": "byName", "options": "project" },
            "properties": [{ "id": "custom.width", "value": 160 }] },
          { "matcher": { "id": "byName", "options": "model" },
            "properties": [{ "id": "custom.width", "value": 200 }] }
        ]
      },
      "transformations": [
        { "id": "labelsToFields", "options": { "mode": "frame" } },
        { "id": "merge", "options": {} },
        { "id": "organize", "options": {
            "renameByName": { "Value": "Tokens", "Value #B": "%" }
          }
        }
      ],
      "targets": [
        { "datasource": { "type": "victoriametrics-metrics-datasource" },
          "expr": "sum by (project, model) (last_over_time(claude_tokens_input_total[$__range]) + last_over_time(claude_tokens_output_total[$__range]))",
          "instant": true, "legendFormat": "", "refId": "A" },
        { "datasource": { "type": "victoriametrics-metrics-datasource" },
          "expr": "sum by (project, model) (last_over_time(claude_tokens_input_total[$__range]) + last_over_time(claude_tokens_output_total[$__range])) / on(project) group_left() sum by (project) (last_over_time(claude_tokens_input_total[$__range]) + last_over_time(claude_tokens_output_total[$__range])) * 100",
          "instant": true, "legendFormat": "", "refId": "B" }
      ]
    }
  ],
  "refresh": "30s",
  "schemaVersion": 38,
  "tags": ["claude", "ai", "metrics"],
  "time": { "from": "now-24h", "to": "now" },
  "timepicker": {},
  "timezone": "browser",
  "title": "Claude Metrics",
  "uid": "claude-metrics-v1",
  "version": 3
}
