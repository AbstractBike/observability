  "panels": [
    {
      "type": "row",
      "title": "Agent Topology",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 0 },
      "collapsed": false
    },
    {
      "type": "nodeGraph",
      "title": "Agent Communication Graph",
      "gridPos": { "h": 12, "w": 24, "x": 0, "y": 1 },
      "datasource": { "type": "prometheus", "uid": "victoriametrics" },
      "targets": [
        {
          "expr": "sum by (from, to) (claude_chat_agent_messages_sent_total)",
          "legendFormat": "{{from}} → {{to}}"
        }
      ]
    },
    {
      "type": "row",
      "title": "Message Traffic",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 13 },
      "collapsed": false
    },
    {
      "type": "heatmap",
      "title": "Inter-Agent Messages (5m rate)",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 14 },
      "datasource": { "type": "prometheus", "uid": "victoriametrics" },
      "targets": [
        {
          "expr": "rate(claude_chat_agent_messages_sent_total[5m])",
          "legendFormat": "{{from}} → {{to}}"
        }
      ]
    },
    {
      "type": "timeseries",
      "title": "Roundtrip Time p95",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 14 },
      "datasource": { "type": "prometheus", "uid": "victoriametrics" },
      "targets": [
        {
          "expr": "histogram_quantile(0.95, rate(claude_chat_agent_roundtrip_seconds_bucket[5m]))",
          "legendFormat": "{{from}} → {{to}}"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "s" } }
    },
    {
      "type": "row",
      "title": "Queue & Errors",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 22 },
      "collapsed": false
    },
    {
      "type": "timeseries",
      "title": "Processing Lag",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 23 },
      "datasource": { "type": "prometheus", "uid": "victoriametrics" },
      "targets": [
        {
          "expr": "claude_chat_agent_processing_lag_seconds",
          "legendFormat": "{{agent}}"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "s" } }
    },
    {
      "type": "timeseries",
      "title": "Rejected Messages",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 23 },
      "datasource": { "type": "prometheus", "uid": "victoriametrics" },
      "targets": [
        {
          "expr": "rate(claude_chat_agent_loop_rejected_total[5m])",
          "legendFormat": "loop: {{from}} → {{to}}"
        },
        {
          "expr": "rate(claude_chat_agent_queue_rejected_total[5m])",
          "legendFormat": "queue: {{agent}}"
        }
      ]
    }
  ],
