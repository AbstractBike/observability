{
  "__inputs": [],
  "__requires": [],
  "annotations": { "list": [] },
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "id": null,
  "links": [
    { "title": "SkyWalking UI", "url": "http://192.168.0.4:8080/", "type": "link", "targetBlank": true },
    { "title": "VictoriaLogs UI", "url": "http://192.168.0.4:9428/vmui", "type": "link", "targetBlank": true }
  ],
  "panels": [
    {
      "type": "row",
      "title": "Metrics ↔ Traces Correlation",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 0 },
      "collapsed": false
    },
    {
      "type": "timeseries",
      "title": "Session Duration with Trace Exemplars",
      "description": "Click exemplar dots to jump to SkyWalking trace",
      "gridPos": { "h": 8, "w": 16, "x": 0, "y": 1 },
      "datasource": { "type": "prometheus", "uid": "victoriametrics" },
      "targets": [
        {
          "expr": "histogram_quantile(0.95, rate(claude_chat_session_duration_seconds_bucket{room=\"$agent\"}[5m]))",
          "legendFormat": "p95",
          "exemplar": true
        },
        {
          "expr": "histogram_quantile(0.50, rate(claude_chat_session_duration_seconds_bucket{room=\"$agent\"}[5m]))",
          "legendFormat": "p50",
          "exemplar": true
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "links": [
            {
              "title": "Open Trace in SkyWalking",
              "url": "http://192.168.0.4:8080/trace?traceId=${__data.fields.trace_id}",
              "targetBlank": true
            }
          ]
        }
      }
    },
    {
      "type": "stat",
      "title": "Avg Latency",
      "gridPos": { "h": 4, "w": 4, "x": 16, "y": 1 },
      "datasource": { "type": "prometheus", "uid": "victoriametrics" },
      "targets": [
        { "expr": "rate(claude_chat_session_duration_seconds_sum{room=\"$agent\"}[5m]) / rate(claude_chat_session_duration_seconds_count{room=\"$agent\"}[5m])" }
      ],
      "fieldConfig": { "defaults": { "unit": "s" } }
    },
    {
      "type": "stat",
      "title": "Error Rate",
      "gridPos": { "h": 4, "w": 4, "x": 20, "y": 1 },
      "datasource": { "type": "prometheus", "uid": "victoriametrics" },
      "targets": [
        { "expr": "rate(claude_chat_session_completed_total{room=\"$agent\",exit!=\"success\"}[5m]) / rate(claude_chat_session_completed_total{room=\"$agent\"}[5m])" }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit",
          "thresholds": { "steps": [
            { "color": "green", "value": 0 },
            { "color": "orange", "value": 0.1 },
            { "color": "red", "value": 0.5 }
          ]}
        }
      }
    },
    {
      "type": "timeseries",
      "title": "MCP Secret Access Latency",
      "gridPos": { "h": 4, "w": 8, "x": 16, "y": 5 },
      "datasource": { "type": "prometheus", "uid": "victoriametrics" },
      "targets": [
        {
          "expr": "histogram_quantile(0.95, rate(claude_chat_mcp_duration_seconds_bucket{agent=\"$agent\"}[5m]))",
          "legendFormat": "{{tool}} p95"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "s" } }
    },
    {
      "type": "row",
      "title": "Logs ↔ Traces Correlation",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 9 },
      "collapsed": false
    },
    {
      "type": "logs",
      "title": "Structured Logs (click trace_id to open trace)",
      "description": "Logs include trace_id field for direct correlation with SkyWalking traces",
      "gridPos": { "h": 12, "w": 24, "x": 0, "y": 10 },
      "datasource": { "type": "victorialogs", "uid": "victorialogs" },
      "targets": [
        {
          "expr": "service:\"claude-chat\" AND room:\"$agent\"",
          "refId": "A"
        }
      ],
      "options": {
        "showLabels": true,
        "enableLogDetails": true
      },
      "fieldConfig": {
        "defaults": {
          "links": [
            {
              "title": "Open Trace",
              "url": "http://192.168.0.4:8080/trace?traceId=${__data.fields.trace_id}",
              "targetBlank": true
            }
          ]
        }
      }
    },
    {
      "type": "row",
      "title": "Traces → Metrics Correlation",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 22 },
      "collapsed": false
    },
    {
      "type": "timeseries",
      "title": "SkyWalking Service Latency (from OAP /metrics)",
      "description": "SkyWalking OAP metrics scraped by VictoriaMetrics for APM correlation",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 23 },
      "datasource": { "type": "prometheus", "uid": "victoriametrics" },
      "targets": [
        {
          "expr": "service_resp_time{service=\"claude-chat\"}",
          "legendFormat": "SkyWalking resp_time"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "ms" } }
    },
    {
      "type": "timeseries",
      "title": "SkyWalking Service SLA",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 23 },
      "datasource": { "type": "prometheus", "uid": "victoriametrics" },
      "targets": [
        {
          "expr": "service_sla{service=\"claude-chat\"} / 100",
          "legendFormat": "SLA %"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "percentunit" } }
    },
    {
      "type": "row",
      "title": "Secret Access Audit",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 31 },
      "collapsed": false
    },
    {
      "type": "table",
      "title": "Secret Access Events",
      "gridPos": { "h": 8, "w": 24, "x": 0, "y": 32 },
      "datasource": { "type": "victorialogs", "uid": "victorialogs" },
      "targets": [
        {
          "expr": "service:\"claude-chat\" AND event:\"secret_access\"",
          "refId": "A"
        }
      ]
    },
    {
      "type": "row",
      "title": "Correlation Guide",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 40 },
      "collapsed": true,
      "panels": [
        {
          "type": "text",
          "title": "How Correlation Works",
          "gridPos": { "h": 6, "w": 24, "x": 0, "y": 41 },
          "options": {
            "mode": "markdown",
            "content": "## Correlation Strategy\n\n| Signal | → | Signal | How |\n|--------|---|--------|-----|\n| **Metrics** | → | **Traces** | Histogram exemplars carry `trace_id` → click → open SkyWalking trace |\n| **Logs** | → | **Traces** | Log field `trace_id` → click → open SkyWalking trace |\n| **Traces** | → | **Logs** | Query VictoriaLogs: `trace_id:\"abc123\"` |\n| **Traces** | → | **Metrics** | SkyWalking OAP `/metrics` scraped by VictoriaMetrics |\n\n**Mandatory fields across all signals:** `service`, `trace_id`, `host`"
          }
        }
      ]
    }
  ],
  "schemaVersion": 39,
  "tags": ["claude-chat", "correlation", "observability"],
  "templating": {
    "list": [
      {
        "name": "agent",
        "type": "query",
        "datasource": { "type": "prometheus", "uid": "victoriametrics" },
        "query": "label_values(claude_chat_session_active, room)",
        "refresh": 2,
        "current": {}
      }
    ]
  },
  "time": { "from": "now-6h", "to": "now" },
  "title": "Claude Chat Unified Correlation",
  "uid": "claude-chat-correlation"
}
